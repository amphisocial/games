NODE_ENV=development
PORT=3000

# Google OAuth 2.0 Web Client ID. No client secret is needed for this GIS ID-token flow.
GOOGLE_CLIENT_ID=000000000000-example.apps.googleusercontent.com

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-secret

# Optional comma-separated allowlist, e.g. example.com,anothercompany.com
ALLOWED_GOOGLE_DOMAINS=

# Local-only convenience. This is ignored in production.
DEV_BYPASS_AUTH=false
