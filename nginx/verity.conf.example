server {
    listen 80;
    server_name verity.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name verity.example.com;

    # Replace with your certificate paths or use Certbot-managed directives.
    ssl_certificate /etc/letsencrypt/live/verity.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/verity.example.com/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }
}
